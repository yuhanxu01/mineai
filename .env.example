# 复制此文件为 .env 并填写真实值
# cp .env.example .env

# Django 核心
SECRET_KEY=your-very-long-random-secret-key-here-change-this
DEBUG=False
ALLOWED_HOSTS=your-domain.com,your-server-ip

# 站点 URL（用于密码重置邮件链接）
SITE_URL=https://your-domain.com

# 数据库（默认 SQLite，生产可换 PostgreSQL）
# DATABASE_URL=postgres://user:pass@localhost:5432/mineai

# 邮件（QQ 邮箱 SMTP）
EMAIL_HOST_USER=your-email@qq.com
EMAIL_HOST_PASSWORD=your-qq-smtp-authorization-code

# OCR Worker 共享令牌（建议生产环境设置）
OCR_WORKER_TOKEN=replace-with-a-long-random-token
